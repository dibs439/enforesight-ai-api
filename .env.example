################################################################################
# ENFORESIGHT API - Environment Configuration Template
# 
# Copy this file to .env (development) or .env.local for local development
# IMPORTANT: Never commit actual .env file with real credentials to GitLab!
################################################################################

# ============================================================================
# SERVER CONFIGURATION
# ============================================================================
NODE_ENV=development
PORT=5011
API_BASE_URL=http://localhost:5011

# ============================================================================
# CONVEX DATABASE CONFIGURATION
# ============================================================================
# Deployment identifier (found in convex dashboard)
# Format: dev:project-name-number or prod:project-name-number
CONVEX_DEPLOYMENT=dev:your-project-name

# Public URL for Convex backend
CONVEX_URL=https://your-project-name.convex.cloud
CONVEX_SITE_URL=https://your-project-name.convex.site

# ============================================================================
# JWT AUTHENTICATION (In-house Admin)
# ============================================================================
# ⚠️ CRITICAL: Change this to a secure random string in production!
# Generate with: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-123456789

# ============================================================================
# CLERK AUTHENTICATION (Customer Portal)
# ============================================================================
# Get these from: https://dashboard.clerk.com/apps
CLERK_PUBLISHABLE_KEY=pk_test_your_publishable_key_here
CLERK_SECRET_KEY=sk_test_your_secret_key_here
CLERK_API_KEY=sk_test_your_api_key_here
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_publishable_key_here
CLERK_WEBHOOK_SECRET=whsec_your_webhook_secret_here
# Comma-separated list of allowed origins/parties for Clerk JWT verification
# e.g. https://enforesight.ai,https://www.enforesight.ai
AUTHORIZED_PARTIES=http://localhost:3000

# ============================================================================
# OPENAI CONFIGURATION
# ============================================================================
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-your-openai-api-key-here

# AI Service — model IDs must match valid OpenAI API identifiers
# See: https://platform.openai.com/docs/models
OPENAI_MODEL=gpt-5.5
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
MAX_TOKENS=800
EMBEDDING_MAX_CHARS=8000
MAX_CONVERSATION_HISTORY=10

# ============================================================================
# SMTP CONFIGURATION (Email Notifications)
# ============================================================================
# Gmail (recommended for development)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-specific-password
SMTP_FROM_EMAIL=your-email@gmail.com
SMTP_FROM_NAME=Enforesight

# ============================================================================
# CORS CONFIGURATION
# ============================================================================
# Comma-separated list of allowed origins
CORS_ORIGIN=http://localhost:3000,http://localhost:3001,https://customer-portal-enforesight.vercel.app,https://enforesight-frontend.onrender.com

# ============================================================================
# FRONTEND CONFIGURATION
# ============================================================================
FRONTEND_URL=http://localhost:5011

# ============================================================================
# LOGGING CONFIGURATION
# ============================================================================
# Pino log level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# ============================================================================
# TESTING CONFIGURATION (Development Only)
# ============================================================================
TEST_MODE=false
TEST_USER_ID=user_your_test_user_id_here

