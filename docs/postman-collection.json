        {
          "name": "Update User Password",
          "request": {
            "method": "PATCH",
            "url": {
              "raw": "{{baseUrl}}/admin/users/{{userId}}/password",
              "host": ["{{baseUrl}}"],
              "path": ["admin", "users", "{{userId}}", "password"]
            },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"password\": \"NewSecureP@ss1\"\n}"
            }
          }
        },
        {
          "name": "Delete User",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/admin/users/{{userId}}",
              "host": ["{{baseUrl}}"],
