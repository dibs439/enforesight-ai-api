      "item": [
        {
          "name": "Search Enforcements",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/customer/portal/enforcement/search",
              "host": ["{{baseUrl}}"],
              "path": ["customer", "portal", "enforcement", "search"]
