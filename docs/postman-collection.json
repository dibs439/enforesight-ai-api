{
  "info": {
    "name": "Enforesight API",
    "description": "Regulatory enforcement intelligence platform — full REST API collection.\n\n**Authentication:**\n- Admin endpoints: obtain a JWT via `POST /admin/users/login`, then set `{{adminToken}}`\n- Customer/AI Chat endpoints: obtain a Clerk session token, then set `{{clerkToken}}`\n\n**Variables:** Set `baseUrl`, `adminToken`, and `clerkToken` in the collection or environment.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_postman_id": "enforesight-api-v1"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000/api/v1",
      "type": "string"
    },
    {
      "key": "adminToken",
      "value": "",
      "type": "string",
      "description": "JWT from POST /admin/users/login"
    },
    {
      "key": "clerkToken",
      "value": "",
      "type": "string",
      "description": "Clerk session token"
    },
    { "key": "userId", "value": "", "type": "string" },
    { "key": "enforcementId", "value": "", "type": "string" },
    { "key": "regulatorId", "value": "", "type": "string" },
    { "key": "clientId", "value": "", "type": "string" },
    { "key": "contentId", "value": "", "type": "string" },
    { "key": "customerId", "value": "", "type": "string" },
    { "key": "conversationId", "value": "", "type": "string" },
    { "key": "messageId", "value": "", "type": "string" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{adminToken}}", "type": "string" }]
  },
  "item": [
    {
      "name": "Health",
      "description": "Server health and status checks",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": ["{{baseUrl}}"],
              "path": ["health"]
            },
            "description": "Returns server status, environment, and dependency health."
          }
        }
      ]
    },
    {
      "name": "Auth",
      "description": "Admin authentication",
      "item": [
        {
          "name": "Admin Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const json = pm.response.json();",
                  "  if (json.token) pm.collectionVariables.set('adminToken', json.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/admin/users/login",
              "host": ["{{baseUrl}}"],
              "path": ["admin", "users", "login"]
            },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@enforesight.com\",\n  \"password\": \"P@ssw0rd123!\"\n}"
            },
            "description": "Authenticate an admin user and receive a JWT token. The test script auto-saves the token to `{{adminToken}}`."
          }
        }
      ]
    },
    {
