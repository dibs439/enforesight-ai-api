{
  "name": "enforesight-api",
  "version": "1.0.0",
  "description": "Express.js API server with TypeScript - Combined with AI Engine capabilities",
  "main": "dist/index.js",
  "scripts": {
    "prebuild": "node scripts/prebuild.js",
    "build": "tsc && node scripts/copy-convex.js",
    "start": "node dist/index.js",
    "dev": "nodemon --exec ts-node ./src/index.ts",
    "dev:inspect": "nodemon --exec \"node --inspect -r ts-node/register ./src/index.ts\"",
    "dev:ts": "ts-node ./src/index.ts",
    "clean": "rm -rf dist",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:integration": "bash tests/integration/run-all-tests.sh",
    "type-check": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,js,json,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,js,json,md}\"",
    "prepare": "husky",
    "convex": "npx convex dev",
    "convex:init": "npx convex run users:initializeDefaultAdminSecure",
    "setup": "echo '📦 Installing dependencies...' && npm install && echo '\n✅ Dependencies installed!' && echo '\n📝 Next steps:' && echo '1. Copy .env.example to .env.local: cp .env.example .env.local' && echo '2. Start Convex: npm run convex' && echo '3. Initialize admin user: npm run convex:init' && echo '4. Start server: npm run dev' && echo '\n📚 See SETUP.md for detailed instructions'"
  },
  "dependencies": {
    "@clerk/express": "^2.1.2",
    "bcryptjs": "^3.0.3",
    "canvas": "^3.2.3",
    "compression": "^1.8.1",
    "convex": "^1.35.1",
    "cors": "^2.8.6",
    "csv-parse": "^6.2.1",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "handlebars": "^4.7.9",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.5",
    "openai": "^6.34.0",
    "pdfjs-dist": "^5.6.205",
    "pdfkit": "^0.18.0",
    "pino": "^10.3.1",
    "svix": "^1.90.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^10.0.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.6.0",
    "@types/nodemailer": "^8.0.0",
    "@types/pdfkit": "^0.17.5",
    "@types/supertest": "^7.2.0",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "eslint": "^10.2.0",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "lint-staged": "^16.4.0",
    "nodemon": "^3.1.14",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.3",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2"
  },
  "overrides": {
    "minimatch": "^10.2.1"
  },
  "keywords": [
    "express",
    "typescript",
    "api",
    "server",
    "ai-engine",
    "chat",
    "enforcement"
  ],
  "author": "",
  "license": "ISC",
  "lint-staged": {
    "*.{ts,js}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ],
    "*.ts": [
      "bash -c 'npm run type-check'"
    ]
  }
}
